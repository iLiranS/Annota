{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Annota",
  "version": "0.1.0",
  "identifier": "online.annota.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "width": 1280,
        "height": 720,
        "title": "",
        "hiddenTitle": true,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' tauri: ipc: https://*.supabase.co wss://*.supabase.co https://annota.online; img-src 'self' asset: http://asset.localhost data: blob: https: https://annota.online; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; child-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "category": "public.app-category.productivity",
    "macOS": {
      "bundleVersion": "6",
      "minimumSystemVersion": "12.0",
      "files": {
        "embedded.provisionprofile": "./embedded.provisionprofile"
      },
      "entitlements": "./entitlements.mas.plist"
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "annota"
        ]
      }
    }
  }
}