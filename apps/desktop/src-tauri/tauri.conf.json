{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Annota Desktop",
  "version": "0.1.0",
  "identifier": "com.annota.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "width": 1200,
        "height": 800,
        "title": "",
        "hiddenTitle": true,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob: https:; tauri: 'unsafe-inline' 'unsafe-eval'; connect-src 'self' tauri: https://*.supabase.co wss://*.supabase.co;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "annota-desktop"
        ]
      }
    }
  }
}