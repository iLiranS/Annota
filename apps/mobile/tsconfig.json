{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ],
      "@annota/editor-core/*": [
        "../../packages/editor-core/*"
      ]
    }
  },
  "include": [
